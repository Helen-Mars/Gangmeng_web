---
import { Icon } from 'astro-icon/components';
import logoImg from '../../assets/gangmeng-logo.png';

const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/en/' },
  { label: 'Products', href: '/en/products' },
  { label: 'Applications', href: '/en/applications' },
  { label: 'Solutions', href: '/en/solutions' },
  { label: 'About Us', href: '/en/about' },
  { label: 'Contact', href: '/en/contact#contact' },
];

const isActive = (href: string) => {
  if (href === '/en/') {
    return currentPath === '/en/' || currentPath === '/en';
  }
  return currentPath.startsWith(href);
};
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-slate-200/80 bg-white/80 backdrop-blur-xl">
  <div class="navbar mx-auto h-16 max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Logo -->
    <div class="navbar-start">
      <div class="dropdown">
        <button
          type="button"
          tabindex="0"
          aria-label="Open navigation menu"
          class="btn btn-ghost btn-sm mr-1 lg:hidden"
        >
          <Icon name="mdi:menu" width="22" height="22" />
        </button>

        <ul
          tabindex="0"
          class="menu menu-sm dropdown-content z-50 mt-3 w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-xl"
        >
          {
            navItems.map((item) => (
                            <li>
                <a
                  href={item.href}
                  class={isActive(item.href) ? 'font-semibold text-cyan-700' : 'text-slate-700'}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <a
        href="/en/"
        class="flex items-center gap-2.5 text-lg font-semibold tracking-tight text-slate-900 transition hover:text-cyan-700 sm:text-xl"
      >
        <img
          src={logoImg.src}
          alt="Gangmeng Sensor"
          class="h-8 w-auto object-contain"
        />
        <span>Gangmeng Sensor</span>
      </a>
    </div>

    <!-- Desktop Navigation -->
    <nav class="navbar-center hidden lg:flex" aria-label="Main navigation">
      <ul class="menu menu-horizontal gap-1 px-1">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={{
                  'relative font-semibold text-cyan-700 after:absolute after:bottom-1 after:left-1/2 after:h-[2px] after:w-5 after:-translate-x-1/2 after:rounded-full after:bg-cyan-600':
                    isActive(item.href),
                  'font-medium text-slate-600 hover:bg-transparent hover:text-cyan-700':
                    !isActive(item.href),
                }}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>


    <!-- Language & CTA -->
    <div class="navbar-end gap-2">
      <div class="items-center rounded-full border border-slate-200 bg-slate-50 p-1">
        <a
          href="/"
          aria-label="切换为中文"
          class="inline-flex h-8 items-center gap-1.5 rounded-full px-3 text-sm font-medium text-slate-500 transition hover:text-cyan-700"
        >
          <Icon
            name="circle-flags:cn"
            width="18"
            height="18"
            aria-hidden="true"
            class="shrink-0"
          />
          <span>中文</span>
        </a>

        <a
          href="/en/"
          aria-label="Switch to English"
          aria-current="page"
          class="inline-flex h-8 items-center gap-1.5 rounded-full bg-white px-3 text-sm font-semibold text-slate-800 shadow-sm"
        >
          <Icon
            name="circle-flags:us"
            width="18"
            height="18"
            aria-hidden="true"
            class="shrink-0"
          />
          <span>EN</span>
        </a>
      </div>

      <a
        href="/en/contact#contact"
        class="btn btn-primary btn-sm hidden rounded-full px-4 sm:inline-flex"
      >
        Get a Quote
        <Icon name="mdi:arrow-up-right" width="16" height="16" />
      </a>
    </div>

  </div>
</header>



