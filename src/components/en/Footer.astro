---
import { Icon } from 'astro-icon/components';
import logoImg from '../../assets/gangmeng-logo.png';
---

<footer class="border-t border-slate-800 bg-slate-950 text-slate-300">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1.5fr_1fr_1fr_1.2fr]">

      <!-- Brand -->
      <div>
        <a href="/en/" class="inline-flex items-center gap-3">
          <img
            src={logoImg.src}
            alt="Gangmeng Sensor"
            class="h-9 w-auto object-contain"
          />
          <span class="text-xl font-semibold tracking-tight text-white">
            Gangmeng Sensor
          </span>
        </a>

        <p class="mt-6 max-w-sm text-sm leading-7 text-slate-400">
          Specializing in FBG fiber optic sensors, DTS distributed temperature
          sensing systems, DAS distributed acoustic sensing systems, and
          intelligent monitoring solutions.
        </p>

        <a
          href="/en/contact#contact"
          class="group mt-7 inline-flex items-center gap-3 text-sm font-medium text-cyan-300 transition hover:text-cyan-200"
        >
          Request a Technical Solution
          <Icon
            name="mdi:arrow-up-right"
            width="17"
            height="17"
            class="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
          />
        </a>
      </div>

      <!-- Products -->
      <nav>
        <h6 class="text-sm font-semibold text-white">Products</h6>

        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a href="/en/products#interrogators" class="transition hover:text-cyan-300">
              Interrogators & Monitoring Instruments
            </a>
          </li>
          <li>
            <a href="/en/products#sensors" class="transition hover:text-cyan-300">
              FBG Fiber Optic Sensors
            </a>
          </li>
          <li>
            <a href="/en/products#ai-monitoring" class="transition hover:text-cyan-300">
              AI Intelligent Monitoring System
            </a>
          </li>
        </ul>
      </nav>

      <!-- Applications & Support -->
      <nav>
        <h6 class="text-sm font-semibold text-white">Applications & Support</h6>

        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a href="/en/applications" class="transition hover:text-cyan-300">
              Applications
            </a>
          </li>
          <li>
            <a href="/en/solutions" class="transition hover:text-cyan-300">
              Featured Solutions
            </a>
          </li>
          <li>
            <a href="/en/downloads" class="transition hover:text-cyan-300">
              Product Downloads
            </a>
          </li>
          <li>
            <a href="/en/support" class="transition hover:text-cyan-300">
              Technical Support
            </a>
          </li>
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <h6 class="text-sm font-semibold text-white">Contact Us</h6>

        <div class="mt-5 space-y-4 text-sm">
          <a
            href="tel:+8617621251612"
            class="group flex items-start gap-3 transition hover:text-cyan-300"
          >
            <Icon
              name="mdi:phone-outline"
              width="18"
              height="18"
              class="mt-0.5 shrink-0 text-cyan-300"
            />
            <span>
              <span class="block text-xs text-slate-500">Phone</span>
              <span class="mt-1 block">+86 176 2125 1612</span>
            </span>
          </a>

          <a
            href="mailto:17621251612@163.com"
            class="group flex items-start gap-3 transition hover:text-cyan-300"
          >
            <Icon
              name="mdi:email-outline"
              width="18"
              height="18"
              class="mt-0.5 shrink-0 text-cyan-300"
            />
            <span>
              <span class="block text-xs text-slate-500">Email</span>
              <span class="mt-1 block">17621251612@163.com</span>
            </span>
          </a>

          <div class="flex items-start gap-3">
            <Icon
              name="mdi:map-marker-outline"
              width="18"
              height="18"
              class="mt-0.5 shrink-0 text-cyan-300"
            />
            <span>
              <span class="block text-xs text-slate-500">Address</span>
              <span class="mt-1 block leading-6">
                China · Room 729, ZeroCube, 3# Innovation Mofang Phase 3, Zhicui Technology Center, Lane 99, Haiji 6th Road, Pudong New Area, Shanghai
              </span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-14 flex flex-col gap-5 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs leading-6 text-slate-500">
        © 2026 Gangmeng Sensor. All Rights Reserved.
      </p>

      <div class="flex items-center gap-1">
        <a
          href="https://www.youtube.com/@GMsensor"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube"
          class="btn btn-ghost btn-sm btn-circle text-slate-400 hover:bg-white/10 hover:text-cyan-300"
        >
          <Icon name="simple-icons:youtube" width="18" height="18" />
        </a>

        <a
          href="https://www.facebook.com/gm.sensor"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="btn btn-ghost btn-sm btn-circle text-slate-400 hover:bg-white/10 hover:text-cyan-300"
        >
          <Icon name="simple-icons:facebook" width="18" height="18" />
        </a>

        <a
          href="https://www.tiktok.com/@gmsensor"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="TikTok"
          class="btn btn-ghost btn-sm btn-circle text-slate-400 hover:bg-white/10 hover:text-cyan-300"
        >
          <Icon name="simple-icons:tiktok" width="18" height="18" />
        </a>

        <a
          href="https://wa.me/861898943763"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp"
          class="btn btn-ghost btn-sm btn-circle text-slate-400 hover:bg-white/10 hover:text-cyan-300"
        >
          <Icon name="simple-icons:whatsapp" width="18" height="18" />
        </a>
      </div>
    </div>
  </div>
</footer>
