---
import { Icon } from 'astro-icon/components';
import logoImg from '../assets/gangmeng-logo.png';

const currentPath = Astro.url.pathname;
const isEnglish = currentPath === '/en' || currentPath.startsWith('/en/');
---

<footer class="border-t border-slate-800 bg-slate-950 text-slate-300">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1.25fr_.9fr_.9fr_.55fr_2fr]">

      <!-- 品牌介绍 -->
      <div>
        <a href="/" class="inline-flex items-center gap-3">
          <img
            src={logoImg.src}
            alt="港盟传感"
            class="h-9 w-auto object-contain"
          />
          <span class="text-xl font-semibold tracking-tight text-white">
            港盟传感
          </span>
        </a>

        <p class="mt-6 max-w-sm text-sm leading-7 text-slate-400">
          专注 FBG 光纤光栅传感器、DTS 分布式测温系统、
          DAS 分布式声波监测系统及智能监测解决方案。
        </p>

        <a
          href="/contact#contact"
          class="group mt-7 inline-flex items-center gap-3 text-sm font-medium text-cyan-300 transition hover:text-cyan-200"
        >
          获取技术方案
          <Icon
            name="mdi:arrow-up-right"
            width="17"
            height="17"
            class="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
          />
        </a>
      </div>

      <!-- 产品中心 -->
      <nav>
        <h6 class="text-sm font-semibold text-white">产品中心</h6>

        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a href="/products#interrogators" class="transition hover:text-cyan-300">
              光纤解调仪（监测仪）
            </a>
          </li>
          <li>
            <a href="/products#sensors" class="transition hover:text-cyan-300">
              光纤传感器
            </a>
          </li>
          <li>
            <a href="/products#ai-monitoring" class="transition hover:text-cyan-300">
              AI 大模型监测系统
            </a>
          </li>
        </ul>
      </nav>

      <!-- 应用与支持 -->
      <nav>
        <h6 class="text-sm font-semibold text-white">应用与支持</h6>

        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a href="/applications" class="transition hover:text-cyan-300">
              应用领域
            </a>
          </li>
          <li>
            <a href="/solutions" class="transition hover:text-cyan-300">
              典型解决方案
            </a>
          </li>
          <li>
            <a href="/downloads" class="transition hover:text-cyan-300">
              产品资料下载
            </a>
          </li>
          <li>
            <a href="/support" class="transition hover:text-cyan-300">
              技术支持
            </a>
          </li>
        </ul>
      </nav>


      <!-- 语言切换 -->
      <div>
        <h6 class="text-sm font-semibold text-white">语言切换</h6>

        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a
              href="/"
              aria-label="切换为中文"
              aria-current={!isEnglish ? 'page' : undefined}
              class:list={{
                'inline-flex items-center gap-2 font-semibold text-cyan-300': !isEnglish,
                'inline-flex items-center gap-2 text-slate-400 transition hover:text-cyan-300': isEnglish,
              }}
            >
              <Icon
                name="circle-flags:cn"
                width="18"
                height="18"
                aria-hidden="true"
              />
              <span>中文</span>
            </a>
          </li>

          <li>
            <a
              href="/en/"
              aria-label="Switch to English"
              aria-current={isEnglish ? 'page' : undefined}
              class:list={{
                'inline-flex items-center gap-2 font-semibold text-cyan-300': isEnglish,
                'inline-flex items-center gap-2 text-slate-400 transition hover:text-cyan-300': !isEnglish,
              }}
            >
              <Icon
                name="circle-flags:us"
                width="18"
                height="18"
                aria-hidden="true"
              />
              <span>English</span>
            </a>
          </li>
        </ul>
      </div>


      <!-- 联系方式 -->
      <div>
        <h6 class="text-sm font-semibold text-white">联系我们</h6>

        <div class="mt-5 space-y-4 text-sm">
          <a
            href="tel:+8617621251612"
            class="group flex items-start gap-3 transition hover:text-cyan-300"
          >
            <Icon
              name="mdi:phone-outline"
              width="18"
              height="18"
              class="mt-0.5 shrink-0 text-cyan-300"
            />
            <span>
              <span class="block text-xs text-slate-500">电话咨询</span>
              <span class="mt-1 block">+86 176 2125 1612</span>
            </span>
          </a>

          <a
            href="mailto:17621251612@163.com"
            class="group flex items-start gap-3 transition hover:text-cyan-300"
          >
            <Icon
              name="mdi:email-outline"
              width="18"
              height="18"
              class="mt-0.5 shrink-0 text-cyan-300"
            />
            <span>
              <span class="block text-xs text-slate-500">邮箱咨询</span>
              <span class="mt-1 block">17621251612@163.com</span>
            </span>
          </a>

          <div class="flex items-start gap-3">
            <Icon
              name="mdi:map-marker-outline"
              width="18"
              height="18"
              class="mt-0.5 shrink-0 text-cyan-300"
            />
            <span>
              <span class="block text-xs text-slate-500">公司地址</span>
              <span class="mt-1 block max-w-md leading-6">
                中国 · 上海市浦东新区<br />
                海基六路 99 弄智萃科技中心创新魔坊 3 期<br />
                3 号楼零界魔方 729 室
              </span>
            </span>
          </div>
        </div>
      </div>


    </div>

    <!-- 底部版权区 -->
    <div class="mt-14 flex flex-col gap-5 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs leading-6 text-slate-500">
        &copy; 2026 港盟传感 · All Rights Reserved.
      </p>

      <div class="flex items-center gap-1">
        <a
          href="https://www.youtube.com/@GMsensor"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube"
          class="btn btn-ghost btn-sm btn-circle text-slate-400 hover:bg-white/10 hover:text-cyan-300"
        >
          <Icon name="simple-icons:youtube" width="18" height="18" />
        </a>

        <a
          href="https://www.facebook.com/gm.sensor"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="btn btn-ghost btn-sm btn-circle text-slate-400 hover:bg-white/10 hover:text-cyan-300"
        >
          <Icon name="simple-icons:facebook" width="18" height="18" />
        </a>

        <a
          href="https://www.tiktok.com/@gmsensor"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="TikTok"
          class="btn btn-ghost btn-sm btn-circle text-slate-400 hover:bg-white/10 hover:text-cyan-300"
        >
          <Icon name="simple-icons:tiktok" width="18" height="18" />
        </a>

        <a
          href="https://wa.me/8618098943763"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp"
          class="btn btn-ghost btn-sm btn-circle text-slate-400 hover:bg-white/10 hover:text-cyan-300"
        >
          <Icon name="simple-icons:whatsapp" width="18" height="18" />
        </a>
      </div>
    </div>
  </div>
</footer>