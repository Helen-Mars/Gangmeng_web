---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const interrogatorProducts = [
  {
    no: '01',
    category: 'FBG INTERROGATOR',
    title: 'FBG 光纤光栅解调仪',
    desc: '用于 FBG 光纤光栅传感器的多通道波长解调、信号采集、实时显示、数据存储与远程传输。',
    tags: ['多通道解调', '高速采集', '远程通信'],
    icon: 'mdi:server-network',
    href: '/products/fbg-interrogator',
  },
  {
    no: '02',
    category: 'DAS MONITORING INSTRUMENT',
    title: 'DAS 光纤分布式声波 / 振动监测仪',
    desc: '基于分布式声波感知技术，对管道、周界、隧道及工业设备的振动、入侵、泄漏与运行状态进行连续监测。',
    tags: ['振动感知', '入侵预警', '泄漏监测'],
    icon: 'mdi:waveform',
    href: '/products/das-monitoring-instrument',
  },
  {
    no: '03',
    category: 'DTS MONITORING INSTRUMENT',
    title: 'DTS 光纤分布式温度监测仪',
    desc: '通过光纤连续测温，实现电力电缆、能源管道、冷库仓储及工业设备的长距离温度监测与热点预警。',
    tags: ['连续测温', '异常热点', '长距离监测'],
    icon: 'mdi:thermometer-lines',
    href: '/products/dts-monitoring-instrument',
  },
];

const fbgProducts = [
  {
    category: 'FBG SENSOR',
    title: 'FBG 光纤光栅应变传感器',
    desc: '适用于桥梁、建筑、隧道及工业结构关键受力部位的长期应变监测。',
    tags: ['应变监测', '高精度', '支持定制'],
    href: '/products/fbg-strain-sensor',
    image: '/images/products/fbg-strain-sensor-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 光纤光栅温度传感器',
    desc: '用于设备、结构、仓储及特殊环境中的精确温度监测与数据采集。',
    tags: ['温度监测', '抗干扰', '多场景适用'],
    href: '/products/fbg-temperature-sensor',
    image: '/images/products/fbg-temperature-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 位移与裂缝传感器',
    desc: '用于结构缝隙、位移变化、沉降变形及关键节点状态的长期监测。',
    tags: ['位移', '裂缝', '结构安全'],
    href: '/products/fbg-displacement-sensor',
    image: '/images/products/fbg-displacement-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 倾角与静力水准仪',
    desc: '适用于建筑、桥梁、基坑及大型结构的倾斜、沉降与差异变形监测。',
    tags: ['倾角', '沉降', '长期监测'],
    href: '/products/fbg-inclinometer',
    image: '/images/products/fbg-inclinometer-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 加速度传感器',
    desc: '用于桥梁、风机、轨道及工业设备的振动响应、模态分析与状态监测。',
    tags: ['振动', '加速度', '状态诊断'],
    href: '/products/fbg-accelerometer',
    image: '/images/products/fbg-accelerometer-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 压力与载荷传感器',
    desc: '面向压力容器、储罐、设备基础及特殊工程对象的压力与载荷监测。',
    tags: ['压力', '载荷', '工程应用'],
    href: '/products/fbg-pressure-sensor',
    image: '/images/products/fbg-pressure-thumbnail.png',
  },
];

const aiFeatures = [
  {
    title: '多源数据统一接入',
    desc: '汇聚光纤解调仪、分布式监测仪、环境设备、视频及第三方系统数据。',
    icon: 'mdi:database-outline',
  },
  {
    title: '智能异常识别',
    desc: '结合阈值、趋势、关联规则与模型分析，识别异常状态与潜在风险。',
    icon: 'mdi:alert-decagram-outline',
  },
  {
    title: '趋势预测与风险研判',
    desc: '对长期监测数据进行变化趋势识别、关联分析与风险等级评估。',
    icon: 'mdi:chart-timeline-variant',
  },
  {
    title: '智能报告与运维辅助',
    desc: '自动生成状态报告、告警记录与运维建议，提升项目管理效率。',
    icon: 'mdi:file-chart-outline',
  },
];
---

<Layout>
  <div slot="content" class="pt-16">
    <!-- ===== 产品中心 Hero ===== -->
    <section class="border-b border-dashed border-slate-200 bg-white px-6 py-16 text-slate-900 lg:px-8 lg:py-20">
      <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.05fr_.95fr] lg:gap-16">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
            <span class="h-px w-8 bg-cyan-600"></span>
            产品中心
          </div>

          <h1 class="mt-5 text-4xl font-semibold leading-[1.15] tracking-tight sm:text-5xl lg:text-6xl">
            光纤感知设备与
            <span class="block text-cyan-600">AI 智能监测系统</span>
          </h1>

          <p class="mt-6 text-base leading-8 text-slate-600 sm:text-lg">
            覆盖 FBG 光纤光栅解调仪、DAS 分布式声波 / 振动监测仪、
            DTS 分布式温度监测仪、FBG 光纤传感器及 AI 大模型监测系统，
            为工程安全、能源设施、工业设备与科研测试提供完整监测能力。
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#interrogators" class="btn btn-primary btn-lg">
              浏览产品
              <Icon name="mdi:arrow-down" width="18" height="18" />
            </a>

            <a
              href="/contact#contact"
              class="btn btn-outline btn-lg border-slate-300 text-slate-700 hover:border-cyan-600 hover:bg-cyan-600 hover:text-white"
            >
              获取选型建议
            </a>
          </div>

          <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3 border-t border-slate-200 pt-6 text-sm text-slate-500">
            <span>标准产品供应</span>
            <span>OEM / ODM 定制</span>
            <span>项目级技术支持</span>
          </div>
        </div>

        <!-- 右侧视觉区 -->
        <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 p-8 sm:p-10">
          <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-cyan-100 blur-3xl"></div>

          <div class="relative grid grid-cols-2 gap-4">
            <div class="rounded-2xl bg-slate-900 p-6 text-white">
              <div class="text-xs font-medium tracking-[0.14em] text-cyan-300">
                INTERROGATOR
              </div>

              <div class="mt-3 text-2xl font-semibold">
                Monitoring
              </div>

              <p class="mt-3 text-sm leading-6 text-slate-400">
                FBG、DAS、DTS 光纤监测设备与数据采集能力。
              </p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-6">
              <div class="text-xs font-medium tracking-[0.14em] text-cyan-700">
                SENSOR
              </div>

              <div class="mt-3 text-2xl font-semibold text-slate-900">
                FBG Sensing
              </div>

              <p class="mt-3 text-sm leading-6 text-slate-500">
                应变、温度、位移、压力、倾角及振动监测。
              </p>
            </div>

            <div class="col-span-2 rounded-2xl border border-cyan-100 bg-cyan-50 p-6">
              <div class="flex items-center justify-between gap-6">
                <div>
                  <div class="text-xs font-medium tracking-[0.14em] text-cyan-700">
                    AI MONITORING SYSTEM
                  </div>

                  <div class="mt-2 text-2xl font-semibold text-slate-900">
                    AI 大模型监测系统
                  </div>
                </div>

                <Icon
                  name="mdi:brain"
                  width="46"
                  height="46"
                  class="shrink-0 text-cyan-600"
                />
              </div>

              <p class="mt-4 text-sm leading-6 text-slate-500">
                多源数据汇聚、智能异常识别、趋势预测与运维辅助决策。
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 产品分类导航 ===== -->
    <div class="sticky top-16 z-40 border-b border-slate-200 bg-white/90 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl gap-6 overflow-x-auto px-6 py-4 text-sm lg:px-8">
        <a
          href="#interrogators"
          class="whitespace-nowrap font-semibold text-cyan-700"
        >
          光纤解调仪（监测仪）
        </a>

        <a
          href="#sensors"
          class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700"
        >
          光纤传感器
        </a>

        <a
          href="#ai-monitoring"
          class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700"
        >
          AI 大模型监测系统
        </a>

        <a
          href="#custom"
          class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700"
        >
          定制化产品
        </a>
      </div>
    </div>

    <!-- ===== 光纤解调仪（监测仪） ===== -->
    <section
      id="interrogators"
      class="scroll-mt-28 border-b border-dashed border-slate-200 bg-slate-50 px-6 py-24 text-slate-900 lg:px-8"
    >
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col justify-between gap-8 lg:flex-row lg:items-end">
          <div class="max-w-2xl">
            <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
              <span class="h-px w-8 bg-cyan-600"></span>
              光纤解调仪（监测仪）
            </div>

            <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
              光纤监测系统核心设备
            </h2>

            <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
              面向 FBG 单点传感、DAS 分布式声波感知及 DTS 分布式温度监测，
              提供从光信号采集、数据解调到在线分析与预警联动的一体化监测设备。
            </p>
          </div>

          <a
            href="/contact#contact"
            class="group inline-flex w-fit items-center gap-3 border-b border-slate-300 pb-2 text-sm font-medium text-slate-700 transition hover:border-cyan-600 hover:text-cyan-700"
          >
            获取设备选型建议
            <span class="text-lg transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>

        <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {
            interrogatorProducts.map((item) => (
              <a
                href={item.href}
                class="group flex min-h-[360px] flex-col rounded-2xl border border-slate-200 bg-white p-7 transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5"
              >
                <div class="flex items-start justify-between">
                  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-50 text-cyan-700">
                    <Icon name={item.icon} width="26" height="26" />
                  </div>

                  <span class="text-sm font-medium text-slate-400">
                    {item.no}
                  </span>
                </div>

                <div class="mt-8 text-xs font-medium tracking-[0.12em] text-cyan-700">
                  {item.category}
                </div>

                <h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">
                  {item.title}
                </h3>

                <p class="mt-4 text-sm leading-7 text-slate-600">
                  {item.desc}
                </p>

                <div class="mt-6 flex flex-wrap gap-2">
                  {
                    item.tags.map((tag) => (
                      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-500">
                        {tag}
                      </span>
                    ))
                  }
                </div>

                <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-5">
                  <span class="text-sm font-medium text-slate-500">
                    查看设备详情
                  </span>

                  <span class="text-lg text-cyan-700 transition-transform group-hover:translate-x-1">
                    →
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== 光纤传感器 ===== -->
    <section
      id="sensors"
      class="scroll-mt-28 border-b border-dashed border-slate-200 bg-white px-6 py-24 text-slate-900 lg:px-8"
    >
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col justify-between gap-8 lg:flex-row lg:items-end">
          <div class="max-w-2xl">
            <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
              <span class="h-px w-8 bg-cyan-600"></span>
              光纤传感器
            </div>

            <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
              FBG 高精度单点光纤感知
            </h2>

            <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
              面向桥梁、建筑、隧道、能源装备、工业设备及科研测试，
              提供应变、温度、位移、裂缝、倾角、沉降、振动、压力与载荷等多参数
              FBG 光纤传感器。
            </p>
          </div>

          <a
            href="/contact#contact"
            class="group inline-flex w-fit items-center gap-3 border-b border-slate-300 pb-2 text-sm font-medium text-slate-700 transition hover:border-cyan-600 hover:text-cyan-700"
          >
            获取传感器选型建议
            <span class="text-lg transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>

        <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {
            fbgProducts.map((item) => (
              <a
                href={item.href}
                class="group flex min-h-[390px] flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5"
              >
                <div class="aspect-[3/2] overflow-hidden bg-slate-50 p-6">
                  <img
                    src={item.image}
                    alt={item.title}
                    class="h-full w-full object-contain transition duration-300 group-hover:scale-105"
                  />
                </div>

                <div class="flex flex-1 flex-col p-6">
                  <div class="text-xs font-medium tracking-[0.12em] text-cyan-700">
                    {item.category}
                  </div>

                  <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900">
                    {item.title}
                  </h3>

                  <p class="mt-3 text-sm leading-7 text-slate-600">
                    {item.desc}
                  </p>

                  <div class="mt-5 flex flex-wrap gap-2">
                    {
                      item.tags.map((tag) => (
                        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-500">
                          {tag}
                        </span>
                      ))
                    }
                  </div>

                  <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-5">
                    <span class="text-sm font-medium text-slate-500">
                      查看产品详情
                    </span>

                    <span class="text-lg text-cyan-700 transition-transform group-hover:translate-x-1">
                      →
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== AI 大模型监测系统 ===== -->
    <section
      id="ai-monitoring"
      class="scroll-mt-28 border-b border-dashed border-slate-800 bg-slate-950 px-6 py-24 text-white lg:px-8"
    >
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1fr_.9fr] lg:items-center">
        <div>
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-300">
            <span class="h-px w-8 bg-cyan-300"></span>
            AI MONITORING SYSTEM
          </div>

          <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
            AI 大模型监测系统
          </h2>

          <p class="mt-6 max-w-2xl text-base leading-8 text-slate-300 sm:text-lg">
            将光纤解调仪、分布式监测仪、FBG 传感器及第三方设备数据统一接入，
            通过数据治理、异常识别、趋势预测、智能告警与运维辅助，
            提升工程监测数据的分析效率与决策价值。
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <span class="rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-2 text-sm text-cyan-200">
              多源数据接入
            </span>

            <span class="rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-2 text-sm text-cyan-200">
              智能异常识别
            </span>

            <span class="rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-2 text-sm text-cyan-200">
              趋势预测分析
            </span>

            <span class="rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-2 text-sm text-cyan-200">
              告警闭环管理
            </span>
          </div>

          <a
            href="/products/ai-monitoring-system"
            class="mt-10 inline-flex items-center gap-3 rounded-xl bg-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300"
          >
            查看 AI 监测系统
            <Icon name="mdi:arrow-up-right" width="18" height="18" />
          </a>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur sm:p-8">
          <div class="grid gap-4 sm:grid-cols-2">
            {
              aiFeatures.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-5">
                  <Icon
                    name={item.icon}
                    width="28"
                    height="28"
                    class="text-cyan-300"
                  />

                  <h3 class="mt-5 text-lg font-semibold">
                    {item.title}
                  </h3>

                  <p class="mt-3 text-sm leading-7 text-slate-400">
                    {item.desc}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 定制化入口 ===== -->
    <section
      id="custom"
      class="scroll-mt-28 border-t border-dashed border-slate-200 bg-gradient-to-br from-cyan-50 via-white to-slate-50 px-6 py-20 text-slate-900 lg:px-8"
    >
      <div class="mx-auto max-w-7xl">
        <div class="overflow-hidden rounded-3xl border border-cyan-100 bg-white shadow-[0_20px_60px_rgba(8,145,178,0.08)]">
          <div class="grid gap-10 p-7 sm:p-10 lg:grid-cols-[1.1fr_.9fr] lg:items-center lg:p-14">
            <div>
              <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
                <span class="h-px w-8 bg-cyan-600"></span>
                OEM / ODM 与定制化产品
              </div>

              <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
                找不到适合项目的
                <span class="block text-cyan-600">标准产品？我们可为您定制。</span>
              </h2>

              <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">
                可根据现场环境、监测对象与系统要求，定制传感器量程、尺寸、
                封装方式、光纤长度、接口形式、耐温等级、防护等级、采集设备及通信方案。
              </p>

              <div class="mt-8 flex flex-wrap gap-3">
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">
                  标准产品快速交付
                </span>

                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">
                  项目级方案适配
                </span>

                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">
                  OEM / ODM 合作
                </span>
              </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-7">
              <div class="text-sm font-medium text-slate-900">
                可定制范围
              </div>

              <div class="mt-5 grid gap-3 text-sm sm:grid-cols-2">
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">传感器尺寸与封装</div>
                  <div class="mt-1 text-xs leading-5 text-slate-500">
                    外形、安装方式、材料与防护结构
                  </div>
                </div>

                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">量程与精度要求</div>
