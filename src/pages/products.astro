---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

// 保留你原本的 Layout import

const fbgProducts = [
  {
    category: 'FBG SENSOR',
    title: 'FBG 光纤光栅应变传感器',
    desc: '适用于桥梁、建筑、隧道及工业结构关键受力部位的长期应变监测。',
    tags: ['应变监测', '高精度', '支持定制'],
    href: '/products/fbg-strain-sensor',
    image: '/images/products/fbg-strain.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 光纤光栅温度传感器',
    desc: '用于设备、结构、仓储及特殊环境中的精确温度监测与数据采集。',
    tags: ['温度监测', '抗干扰', '多场景适用'],
    href: '/products/fbg-temperature-sensor',
    image: '/images/products/fbg-temperature.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 位移与裂缝传感器',
    desc: '用于结构缝隙、位移变化、沉降变形及关键节点状态的长期监测。',
    tags: ['位移', '裂缝', '结构安全'],
    href: '/products/fbg-displacement-sensor',
    image: '/images/products/fbg-displacement.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 倾角与静力水准仪',
    desc: '适用于建筑、桥梁、基坑及大型结构的倾斜、沉降与差异变形监测。',
    tags: ['倾角', '沉降', '长期监测'],
    href: '/products/fbg-inclinometer',
    image: '/images/products/fbg-inclinometer.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 加速度传感器',
    desc: '用于桥梁、风机、轨道及工业设备的振动响应、模态分析与状态监测。',
    tags: ['振动', '加速度', '状态诊断'],
    href: '/products/fbg-accelerometer',
    image: '/images/products/fbg-accelerometer.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG 压力与载荷传感器',
    desc: '面向压力容器、储罐、设备基础及特殊工程对象的压力与载荷监测。',
    tags: ['压力', '载荷', '工程应用'],
    href: '/products/fbg-pressure-sensor',
    image: '/images/products/fbg-pressure.jpg',
  },
];

const platformProducts = [
  {
    no: '01',
    title: 'FBG 光纤解调仪',
    desc: '用于多通道 FBG 传感器信号采集、波长解调、实时显示与数据传输。',
    href: '/products/interrogators',
  },
  {
    no: '02',
    title: '智能数据采集主机',
    desc: '支持现场采集、边缘处理、远程通信及多类传感器接入。',
    href: '/products/data-acquisition',
  },
  {
    no: '03',
    title: '监测分析与预警平台',
    desc: '实现数据可视化、趋势分析、阈值告警、报表导出与远程运维。',
    href: '/products/software-platform',
  },
];
---

<Layout>
  <div slot="content" class="pt-16">

    <!-- ===== 产品中心 Hero ===== -->
    <section class="border-b border-dashed border-slate-200 bg-white px-6 py-16 text-slate-900 lg:px-8 lg:py-20">
      <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.05fr_.95fr] lg:gap-16">

        <div class="max-w-2xl">
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
            <span class="h-px w-8 bg-cyan-600"></span>
            产品中心
          </div>

          <h1 class="mt-5 text-4xl font-semibold leading-[1.15] tracking-tight sm:text-5xl lg:text-6xl">
            光纤传感产品与
            <span class="block text-cyan-600">智能监测系统</span>
          </h1>

          <p class="mt-6 text-base leading-8 text-slate-600 sm:text-lg">
            覆盖 FBG 光纤光栅传感器、DTS 分布式测温系统、
            DAS 分布式声波监测系统、光纤解调仪、采集主机及监测平台，
            满足科研、工业与工程安全监测需求。
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#fbg" class="btn btn-primary btn-lg">
              浏览产品
              <Icon name="mdi:arrow-down" width="18" height="18" />
            </a>

            <a
              href="/contact#contact"
              class="btn btn-outline btn-lg border-slate-300 text-slate-700 hover:border-cyan-600 hover:bg-cyan-600 hover:text-white"
            >
              获取选型建议
            </a>
          </div>

          <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3 border-t border-slate-200 pt-6 text-sm text-slate-500">
            <span>标准产品供应</span>
            <span>OEM / ODM 定制</span>
            <span>项目级技术支持</span>
          </div>
        </div>

        <!-- 产品视觉区：后续可替换为主机 + 传感器组合图 -->
        <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 p-8 sm:p-10">
          <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-cyan-100 blur-3xl"></div>

          <div class="relative grid grid-cols-2 gap-4">
            <div class="rounded-2xl border border-slate-200 bg-white p-6">
              <div class="text-xs font-medium tracking-[0.14em] text-cyan-700">
                FBG
              </div>
              <div class="mt-3 text-2xl font-semibold text-slate-900">
                Point Sensing
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-500">
                应变、温度、位移、压力、倾角及振动监测。
              </p>
            </div>

            <div class="rounded-2xl bg-slate-900 p-6 text-white">
              <div class="text-xs font-medium tracking-[0.14em] text-cyan-300">
                DTS
              </div>
              <div class="mt-3 text-2xl font-semibold">
                Temperature
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-400">
                长距离连续温度监测与异常热点预警。
              </p>
            </div>

            <div class="col-span-2 rounded-2xl border border-slate-200 bg-white p-6">
              <div class="flex items-center justify-between gap-6">
                <div>
                  <div class="text-xs font-medium tracking-[0.14em] text-cyan-700">
                    DAS
                  </div>
                  <div class="mt-2 text-2xl font-semibold text-slate-900">
                    Distributed Acoustic Sensing
                  </div>
                </div>

                <Icon
                  name="mdi:waveform"
                  width="46"
                  height="46"
                  class="shrink-0 text-cyan-600"
                />
              </div>

              <p class="mt-4 text-sm leading-6 text-slate-500">
                实时感知振动、入侵、泄漏及设备运行状态。
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 产品分类导航 ===== -->
    <div class="sticky top-16 z-40 border-b border-slate-200 bg-white/90 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl gap-6 overflow-x-auto px-6 py-4 text-sm lg:px-8">
        <a href="#fbg" class="whitespace-nowrap font-semibold text-cyan-700">
          FBG 传感器
        </a>
        <a href="#dts-das" class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700">
          DTS / DAS 系统
        </a>
        <a href="#platform" class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700">
          解调仪与平台
        </a>
        <a href="#custom" class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700">
          定制化产品
        </a>
      </div>
    </div>

    <!-- ===== FBG 产品 ===== -->
    <section id="fbg" class="scroll-mt-28 border-b border-dashed border-slate-200 bg-slate-50 px-6 py-24 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col justify-between gap-8 lg:flex-row lg:items-end">
          <div class="max-w-2xl">
            <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
              <span class="h-px w-8 bg-cyan-600"></span>
              FBG 光纤光栅传感器
            </div>

            <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
              高精度单点光纤感知
            </h2>

            <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
              面向结构安全、工业设备、能源设施及科研测试，
              提供多类型 FBG 光纤传感器与定制封装方案。
            </p>
          </div>

          <a
            href="/products/fbg"
            class="group inline-flex w-fit items-center gap-3 border-b border-slate-300 pb-2 text-sm font-medium text-slate-700 transition hover:border-cyan-600 hover:text-cyan-700"
          >
            查看全部 FBG 产品
            <span class="text-lg transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>

        <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {
            fbgProducts.map((item) => (
              <a
                href={item.href}
                class="group flex min-h-[390px] flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5"
              >
                <div class="flex h-48 items-center justify-center bg-slate-50 p-6">
                  <img
                    src={item.image}
                    alt={item.title}
                    class="h-full w-full object-contain transition duration-300 group-hover:scale-105"
                  />
                </div>

                <div class="flex flex-1 flex-col p-6">
                  <div class="text-xs font-medium tracking-[0.12em] text-cyan-700">
                    {item.category}
                  </div>

                  <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900">
                    {item.title}
                  </h3>

                  <p class="mt-3 text-sm leading-7 text-slate-600">
                    {item.desc}
                  </p>

                  <div class="mt-5 flex flex-wrap gap-2">
                    {
                      item.tags.map((tag) => (
                        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-500">
                          {tag}
                        </span>
                      ))
                    }
                  </div>

                  <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-5">
                    <span class="text-sm font-medium text-slate-500">
                      查看产品详情
                    </span>
                    <span class="text-lg text-cyan-700 transition-transform group-hover:translate-x-1">
                      →
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== DTS / DAS 系统 ===== -->
    <section id="dts-das" class="scroll-mt-28 border-b border-dashed border-slate-200 bg-white px-6 py-24 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
            <span class="h-px w-8 bg-cyan-600"></span>
            分布式监测系统
          </div>

          <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
            长距离连续光纤感知
          </h2>

          <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
            DTS 与 DAS 面向电缆、管道、周界、隧道、仓储及工业设备等场景，
            实现连续、实时、高密度的监测与预警。
          </p>
        </div>

        <div class="mt-14 grid gap-6 lg:grid-cols-2">
          <!-- DTS -->
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-50">
            <div class="grid h-full lg:grid-cols-[.9fr_1.1fr]">
              <div class="flex min-h-[260px] items-center justify-center bg-slate-900 p-8 text-white">
                <div>
                  <div class="text-sm font-medium tracking-[0.14em] text-cyan-300">
                    DTS SYSTEM
                  </div>
                  <div class="mt-4 text-5xl font-semibold">DTS</div>
                  <div class="mt-3 text-sm leading-7 text-slate-400">
                    Distributed Temperature Sensing
                  </div>
                </div>
              </div>

              <div class="flex flex-col p-8">
                <h3 class="text-2xl font-semibold text-slate-900">
                  DTS 分布式测温系统
                </h3>

                <p class="mt-4 text-sm leading-7 text-slate-600">
                  通过光纤连续测温实现长距离、多区域、高密度温度监测，
                  支持异常热点识别、趋势分析及预警联动。
                </p>

                <div class="mt-6 flex flex-wrap gap-2">
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">电力电缆</span>
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">能源管道</span>
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">冷库仓储</span>
                </div>

                <a
                  href="/products/dts"
                  class="mt-auto inline-flex w-fit items-center gap-3 pt-8 text-sm font-medium text-cyan-700 transition hover:text-cyan-600"
                >
                  查看 DTS 系统
                  <span class="text-lg">→</span>
                </a>
              </div>
            </div>
          </div>

          <!-- DAS -->
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-50">
            <div class="grid h-full lg:grid-cols-[.9fr_1.1fr]">
              <div class="flex min-h-[260px] items-center justify-center bg-cyan-700 p-8 text-white">
                <div>
                  <div class="text-sm font-medium tracking-[0.14em] text-cyan-100">
                    DAS SYSTEM
                  </div>
                  <div class="mt-4 text-5xl font-semibold">DAS</div>
                  <div class="mt-3 text-sm leading-7 text-cyan-100/80">
                    Distributed Acoustic Sensing
                  </div>
                </div>
              </div>

              <div class="flex flex-col p-8">
                <h3 class="text-2xl font-semibold text-slate-900">
                  DAS 分布式声波监测系统
                </h3>

                <p class="mt-4 text-sm leading-7 text-slate-600">
                  基于光纤对振动、声波、入侵、泄漏及设备运行状态进行实时感知，
                  适用于长距离分布式安全监测与状态诊断。
                </p>

                <div class="mt-6 flex flex-wrap gap-2">
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">周界安防</span>
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">管道泄漏</span>
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">设备振动</span>
                </div>

                <a
                  href="/products/das"
                  class="mt-auto inline-flex w-fit items-center gap-3 pt-8 text-sm font-medium text-cyan-700 transition hover:text-cyan-600"
                >
                  查看 DAS 系统
                  <span class="text-lg">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 解调仪与平台 ===== -->
    <section id="platform" class="scroll-mt-28 border-b border-dashed border-slate-200 bg-slate-50 px-6 py-24 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
            <span class="h-px w-8 bg-cyan-600"></span>
            解调仪与监测平台
          </div>

          <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
            从数据采集到智能预警
          </h2>

          <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
            配套解调、采集、通信与数据分析能力，
            构建可扩展、可远程运维的智能光纤监测系统。
          </p>
        </div>

        <div class="mt-14 grid gap-5 md:grid-cols-3">
          {
            platformProducts.map((item) => (
              <a
                href={item.href}
                class="group min-h-[260px] rounded-2xl border border-slate-200 bg-white p-7 transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5"
              >
                <div class="flex items-start justify-between">
                  <span class="text-sm font-medium text-cyan-700">{item.no}</span>
                  <span class="text-lg text-slate-400 transition-transform group-hover:translate-x-1 group-hover:text-cyan-700">→</span>
                </div>

                <h3 class="mt-10 text-2xl font-semibold tracking-tight text-slate-900">
                  {item.title}
                </h3>

                <p class="mt-4 text-sm leading-7 text-slate-600">
                  {item.desc}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== 定制化入口 ===== -->
    <section
    id="custom"
    class="scroll-mt-28 border-t border-dashed border-slate-200 bg-gradient-to-br from-cyan-50 via-white to-slate-50 px-6 py-20 text-slate-900 lg:px-8"
    >
    <div class="mx-auto max-w-7xl">
        <div class="overflow-hidden rounded-3xl border border-cyan-100 bg-white shadow-[0_20px_60px_rgba(8,145,178,0.08)]">
        <div class="grid gap-10 p-7 sm:p-10 lg:grid-cols-[1.1fr_.9fr] lg:items-center lg:p-14">

            <!-- 左侧说明 -->
            <div>
            <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
                <span class="h-px w-8 bg-cyan-600"></span>
                OEM / ODM 与定制化产品
            </div>

            <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
                找不到适合项目的
                <span class="block text-cyan-600">标准产品？我们可为您定制。</span>
            </h2>

            <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">
                可根据现场环境、监测对象与系统要求，定制传感器量程、尺寸、
                封装方式、光纤长度、接口形式、耐温等级、防护等级及通信方案。
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">
                标准产品快速交付
                </span>
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">
                项目级方案适配
                </span>
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">
                OEM / ODM 合作
                </span>
            </div>
            </div>

            <!-- 右侧定制范围 -->
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-7">
            <div class="text-sm font-medium text-slate-900">
                可定制范围
            </div>

            <div class="mt-5 grid gap-3 text-sm sm:grid-cols-2">
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                <div class="font-medium text-slate-900">传感器尺寸与封装</div>
                <div class="mt-1 text-xs leading-5 text-slate-500">
                    外形、安装方式、材料与防护结构
                </div>
                </div>

                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                <div class="font-medium text-slate-900">量程与精度要求</div>
                <div class="mt-1 text-xs leading-5 text-slate-500">
                    面向不同监测对象优化参数配置
                </div>
                </div>

                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                <div class="font-medium text-slate-900">特殊安装环境</div>
                <div class="mt-1 text-xs leading-5 text-slate-500">
                    高温、潮湿、腐蚀、户外及狭小空间
                </div>
                </div>

                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                <div class="font-medium text-slate-900">通信与系统集成</div>
                <div class="mt-1 text-xs leading-5 text-slate-500">
                    数据采集、协议接入与平台协同
                </div>
                </div>
            </div>

            <a
                href="/contact#contact"
                class="mt-7 inline-flex items-center gap-3 rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-cyan-700"
            >
                联系技术团队
                <Icon name="mdi:arrow-up-right" width="17" height="17" />
            </a>
            </div>

        </div>
        </div>
    </div>
    </section>

  </div>
</Layout>

