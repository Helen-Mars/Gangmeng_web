---
import Layout from '@/layouts/en/Layout.astro';
import { Icon } from 'astro-icon/components';

const fbgProducts = [
  {
    category: 'FBG SENSOR',
    title: 'FBG Strain Sensor',
    desc: 'Long-term strain monitoring for bridges, buildings, tunnels, and critical structural components.',
    tags: ['Strain', 'High Precision', 'Customizable'],
    href: '/en/products/fbg-strain-sensor',
    image: '/images/products/fbg-strain.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Temperature Sensor',
    desc: 'Precise temperature monitoring for equipment, structures, storage, and special environments.',
    tags: ['Temperature', 'Anti-Interference', 'Multi-Scenario'],
    href: '/en/products/fbg-temperature-sensor',
    image: '/images/products/fbg-temperature.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Displacement & Crack Sensor',
    desc: 'Long-term monitoring of structural gaps, displacement, settlement, and critical joint conditions.',
    tags: ['Displacement', 'Crack', 'Structural Safety'],
    href: '/en/products/fbg-displacement-sensor',
    image: '/images/products/fbg-displacement.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Inclinometer & Tilt Sensor',
    desc: 'Tilt, settlement, and differential deformation monitoring for buildings, bridges, and large structures.',
    tags: ['Tilt', 'Settlement', 'Long-Term'],
    href: '/en/products/fbg-inclinometer',
    image: '/images/products/fbg-inclinometer.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Accelerometer',
    desc: 'Vibration response, modal analysis, and condition monitoring for bridges, turbines, rail, and industrial equipment.',
    tags: ['Vibration', 'Acceleration', 'Diagnostics'],
    href: '/en/products/fbg-accelerometer',
    image: '/images/products/fbg-accelerometer.jpg',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Pressure & Load Sensor',
    desc: 'Pressure and load monitoring for vessels, tanks, foundations, and special engineering applications.',
    tags: ['Pressure', 'Load', 'Industrial'],
    href: '/en/products/fbg-pressure-sensor',
    image: '/images/products/fbg-pressure.jpg',
  },
];
const platformProducts = [
  {
    no: '01',
    title: 'FBG Optical Interrogator',
    desc: 'Multi-channel FBG sensor signal acquisition, wavelength demodulation, real-time display, and data transmission.',
    href: '/en/products/interrogators',
  },
  {
    no: '02',
    title: 'Smart Data Acquisition Unit',
    desc: 'Supports on-site acquisition, edge processing, remote communication, and multi-type sensor integration.',
    href: '/en/products/data-acquisition',
  },
  {
    no: '03',
    title: 'Monitoring & Analysis Platform',
    desc: 'Data visualization, trend analysis, threshold alerting, report export, and remote O&M.',
    href: '/en/products/software-platform',
  },
];
---
<Layout>
  <div slot="content" class="pt-16">

    <!-- ===== Hero ===== -->
    <section class="border-b border-dashed border-slate-200 bg-white px-6 py-16 text-slate-900 lg:px-8 lg:py-20">
      <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.05fr_.95fr] lg:gap-16">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
            <span class="h-px w-8 bg-cyan-600"></span>
            Products
          </div>
          <h1 class="mt-5 text-4xl font-semibold leading-[1.15] tracking-tight sm:text-5xl lg:text-6xl">
            Fiber Optic Sensing Products
            <span class="block text-cyan-600">& Intelligent Monitoring Systems</span>
          </h1>
          <p class="mt-6 text-base leading-8 text-slate-600 sm:text-lg">
            Covering FBG sensors, DTS temperature sensing, DAS acoustic sensing, interrogators,
            data acquisition units, and monitoring platforms for research, industrial, and engineering applications.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#fbg" class="btn btn-primary btn-lg">
              Browse Products
              <Icon name="mdi:arrow-down" width="18" height="18" />
            </a>
            <a href="/en/#contact" class="btn btn-outline btn-lg border-slate-300 text-slate-700 hover:border-cyan-600 hover:bg-cyan-600 hover:text-white">
              Get Selection Advice
            </a>
          </div>
          <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3 border-t border-slate-200 pt-6 text-sm text-slate-500">
            <span>Standard Products</span>
            <span>OEM / ODM Custom</span>
            <span>Project-Level Support</span>
          </div>
        </div>
        <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 p-8 sm:p-10">
          <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-cyan-100 blur-3xl"></div>
          <div class="relative grid grid-cols-2 gap-4">
            <div class="rounded-2xl border border-slate-200 bg-white p-6">
              <div class="text-xs font-medium tracking-[0.14em] text-cyan-700">FBG</div>
              <div class="mt-3 text-2xl font-semibold text-slate-900">Point Sensing</div>
              <p class="mt-3 text-sm leading-6 text-slate-500">Strain, temperature, displacement, pressure, tilt & vibration.</p>
            </div>
            <div class="rounded-2xl bg-slate-900 p-6 text-white">
              <div class="text-xs font-medium tracking-[0.14em] text-cyan-300">DTS</div>
              <div class="mt-3 text-2xl font-semibold">Temperature</div>
              <p class="mt-3 text-sm leading-6 text-slate-400">Long-range continuous temperature monitoring & hot spot warning.</p>
            </div>
            <div class="col-span-2 rounded-2xl border border-slate-200 bg-white p-6">
              <div class="flex items-center justify-between gap-6">
                <div>
                  <div class="text-xs font-medium tracking-[0.14em] text-cyan-700">DAS</div>
                  <div class="mt-2 text-2xl font-semibold text-slate-900">Distributed Acoustic Sensing</div>
                </div>
                <Icon name="mdi:waveform" width="46" height="46" class="shrink-0 text-cyan-600" />
              </div>
              <p class="mt-4 text-sm leading-6 text-slate-500">Real-time sensing of vibration, intrusion, leaks, and equipment status.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Sticky Nav ===== -->
    <div class="sticky top-16 z-40 border-b border-slate-200 bg-white/90 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl gap-6 overflow-x-auto px-6 py-4 text-sm lg:px-8">
        <a href="#fbg" class="whitespace-nowrap font-semibold text-cyan-700">FBG Sensors</a>
        <a href="#dts-das" class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700">DTS / DAS Systems</a>
        <a href="#platform" class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700">Interrogators & Platforms</a>
        <a href="#custom" class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700">Custom Products</a>
      </div>
    </div>

    <!-- ===== FBG Section ===== -->
    <section id="fbg" class="scroll-mt-28 border-b border-dashed border-slate-200 bg-slate-50 px-6 py-24 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col justify-between gap-8 lg:flex-row lg:items-end">
          <div class="max-w-2xl">
            <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
              <span class="h-px w-8 bg-cyan-600"></span>
              FBG Fiber Bragg Grating Sensors
            </div>
            <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">High-Precision Point Sensing</h2>
            <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
              Offering a wide range of FBG fiber optic sensors and custom packaging solutions
              for structural safety, industrial equipment, energy facilities, and research.
            </p>
          </div>
          <a href="/en/products/fbg" class="group inline-flex w-fit items-center gap-3 border-b border-slate-300 pb-2 text-sm font-medium text-slate-700 transition hover:border-cyan-600 hover:text-cyan-700">
            View All FBG Products
            <span class="text-lg transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
        <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {fbgProducts.map((item) => (
            <a href={item.href} class="group flex min-h-[390px] flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5">
              <div class="flex h-48 items-center justify-center bg-slate-50 p-6">
                <img src={item.image} alt={item.title} class="h-full w-full object-contain transition duration-300 group-hover:scale-105" />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="text-xs font-medium tracking-[0.12em] text-cyan-700">{item.category}</div>
                <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{item.desc}</p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {item.tags.map((tag) => (<span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-500">{tag}</span>))}
                </div>
                <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-5">
                  <span class="text-sm font-medium text-slate-500">View Details</span>
                  <span class="text-lg text-cyan-700 transition-transform group-hover:translate-x-1">→</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== DTS / DAS ===== -->
    <section id="dts-das" class="scroll-mt-28 border-b border-dashed border-slate-200 bg-white px-6 py-24 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
            <span class="h-px w-8 bg-cyan-600"></span>
            Distributed Monitoring Systems
          </div>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">Long-Range Continuous Fiber Sensing</h2>
          <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
            DTS and DAS deliver continuous, real-time, high-density monitoring and early warning
            for cables, pipelines, perimeters, tunnels, storage, and industrial equipment.
          </p>
        </div>
        <div class="mt-14 grid gap-6 lg:grid-cols-2">
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-50">
            <div class="grid h-full lg:grid-cols-[.9fr_1.1fr]">
              <div class="flex min-h-[260px] items-center justify-center bg-slate-900 p-8 text-white">
                <div>
                  <div class="text-sm font-medium tracking-[0.14em] text-cyan-300">DTS SYSTEM</div>
                  <div class="mt-4 text-5xl font-semibold">DTS</div>
                  <div class="mt-3 text-sm leading-7 text-slate-400">Distributed Temperature Sensing</div>
                </div>
              </div>
              <div class="flex flex-col p-8">
                <h3 class="text-2xl font-semibold text-slate-900">DTS Distributed Temperature Sensing</h3>
                <p class="mt-4 text-sm leading-7 text-slate-600">
                  Continuous fiber-optic temperature monitoring for long-distance, multi-zone applications,
                  supporting hot spot identification, trend analysis, and alarm integration.
                </p>
                <div class="mt-6 flex flex-wrap gap-2">
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">Power Cables</span>
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">Energy Pipelines</span>
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">Cold Storage</span>
                </div>
                <a href="/en/products/dts" class="mt-auto inline-flex w-fit items-center gap-3 pt-8 text-sm font-medium text-cyan-700 transition hover:text-cyan-600">
                  View DTS System <span class="text-lg">→</span>
                </a>
              </div>
            </div>
          </div>
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-50">
            <div class="grid h-full lg:grid-cols-[.9fr_1.1fr]">
              <div class="flex min-h-[260px] items-center justify-center bg-cyan-700 p-8 text-white">
                <div>
                  <div class="text-sm font-medium tracking-[0.14em] text-cyan-100">DAS SYSTEM</div>
                  <div class="mt-4 text-5xl font-semibold">DAS</div>
                  <div class="mt-3 text-sm leading-7 text-cyan-100/80">Distributed Acoustic Sensing</div>
                </div>
              </div>
              <div class="flex flex-col p-8">
                <h3 class="text-2xl font-semibold text-slate-900">DAS Distributed Acoustic Sensing</h3>
                <p class="mt-4 text-sm leading-7 text-slate-600">
                  Real-time sensing of vibration, acoustic signals, intrusion, leaks, and equipment
                  operating conditions for long-distance distributed monitoring.
                </p>
                <div class="mt-6 flex flex-wrap gap-2">
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">Perimeter Security</span>
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">Pipeline Leak</span>
                  <span class="rounded-full bg-white px-3 py-1 text-xs text-slate-500">Machine Vibration</span>
                </div>
                <a href="/en/products/das" class="mt-auto inline-flex w-fit items-center gap-3 pt-8 text-sm font-medium text-cyan-700 transition hover:text-cyan-600">
                  View DAS System <span class="text-lg">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Platform ===== -->
    <section id="platform" class="scroll-mt-28 border-b border-dashed border-slate-200 bg-slate-50 px-6 py-24 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
            <span class="h-px w-8 bg-cyan-600"></span>
            Interrogators & Monitoring Platforms
          </div>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">From Data Acquisition to Smart Alerts</h2>
          <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
            Complete interrogation, acquisition, communication, and analytics capabilities
            for scalable, remotely operated fiber optic monitoring systems.
          </p>
        </div>
        <div class="mt-14 grid gap-5 md:grid-cols-3">
          {platformProducts.map((item) => (
            <a href={item.href} class="group min-h-[260px] rounded-2xl border border-slate-200 bg-white p-7 transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5">
              <div class="flex items-start justify-between">
                <span class="text-sm font-medium text-cyan-700">{item.no}</span>
                <span class="text-lg text-slate-400 transition-transform group-hover:translate-x-1 group-hover:text-cyan-700">→</span>
              </div>
              <h3 class="mt-10 text-2xl font-semibold tracking-tight text-slate-900">{item.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">{item.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== Custom ===== -->
    <section id="custom" class="scroll-mt-28 border-t border-dashed border-slate-200 bg-gradient-to-br from-cyan-50 via-white to-slate-50 px-6 py-20 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="overflow-hidden rounded-3xl border border-cyan-100 bg-white shadow-[0_20px_60px_rgba(8,145,178,0.08)]">
          <div class="grid gap-10 p-7 sm:p-10 lg:grid-cols-[1.1fr_.9fr] lg:items-center lg:p-14">
            <div>
              <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
                <span class="h-px w-8 bg-cyan-600"></span>
                OEM / ODM & Custom Products
              </div>
              <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
                Can't Find the Right
                <span class="block text-cyan-600">Standard Product? We Customize.</span>
              </h2>
              <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">
                Custom sensor ranges, dimensions, packaging, fiber length, connectors,
                temperature rating, protection class, and communication protocols
                based on site conditions and system requirements.
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">Fast Delivery</span>
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">Project Adaptation</span>
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">OEM / ODM</span>
              </div>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-7">
              <div class="text-sm font-medium text-slate-900">Customization Scope</div>
              <div class="mt-5 grid gap-3 text-sm sm:grid-cols-2">
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">Size & Packaging</div>
                  <div class="mt-1 text-xs leading-5 text-slate-500">Form factor, mounting, materials & protection</div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">Range & Accuracy</div>
                  <div class="mt-1 text-xs leading-5 text-slate-500">Optimized parameters for different applications</div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">Special Environments</div>
                  <div class="mt-1 text-xs leading-5 text-slate-500">High temp, humidity, corrosion, outdoor & tight spaces</div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">System Integration</div>
                  <div class="mt-1 text-xs leading-5 text-slate-500">Data acquisition, protocol & platform coordination</div>
                </div>
              </div>
              <a href="/en/#contact" class="mt-7 inline-flex items-center gap-3 rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-cyan-700">
                Contact Technical Team
                <Icon name="mdi:arrow-up-right" width="17" height="17" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>
</Layout>
