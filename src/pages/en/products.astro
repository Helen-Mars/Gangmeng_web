---
import Layout from '@/layouts/en/Layout.astro';
import { Icon } from 'astro-icon/components';

const interrogatorProducts = [
  {
    no: '01',
    category: 'FBG INTERROGATOR',
    title: 'FBG Fiber Optic Interrogator',
    desc: 'Multi-channel wavelength demodulation, signal acquisition, real-time display, data storage, and remote transmission for FBG sensors.',
    tags: ['Multi-Channel', 'High-Speed', 'Remote Communication'],
    icon: 'mdi:server-network',
    href: '/en/products/fbg-interrogator',
  },
  {
    no: '02',
    category: 'DAS MONITORING INSTRUMENT',
    title: 'DAS Distributed Acoustic / Vibration Monitor',
    desc: 'Continuous monitoring of vibration, intrusion, leakage, and operating conditions for pipelines, perimeters, tunnels, and industrial equipment.',
    tags: ['Vibration Sensing', 'Intrusion Alert', 'Leak Monitoring'],
    icon: 'mdi:waveform',
    href: '/en/products/das-monitoring-instrument',
  },
  {
    no: '03',
    category: 'DTS MONITORING INSTRUMENT',
    title: 'DTS Distributed Temperature Monitor',
    desc: 'Continuous fiber-optic temperature monitoring for power cables, energy pipelines, cold storage, and industrial equipment with hot-spot alerting.',
    tags: ['Continuous Temperature', 'Hot Spot', 'Long-Distance'],
    icon: 'mdi:thermometer-lines',
    href: '/en/products/dts-monitoring-instrument',
  },
];

const fbgProducts = [
  {
    category: 'FBG SENSOR',
    title: 'FBG Strain Sensor',
    desc: 'Long-term strain monitoring for bridges, buildings, tunnels, and critical structural components.',
    tags: ['Strain', 'High Precision', 'Customizable'],
    href: '/en/products/fbg-strain-sensor',
    image: '/images/products/fbg-strain-sensor-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Temperature Sensor',
    desc: 'Precise temperature monitoring for equipment, structures, storage, and special environments.',
    tags: ['Temperature', 'Anti-Interference', 'Multi-Scenario'],
    href: '/en/products/fbg-temperature-sensor',
    image: '/images/products/fbg-temperature-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Displacement & Crack Sensor',
    desc: 'Long-term monitoring of structural gaps, displacement, settlement, and critical joint conditions.',
    tags: ['Displacement', 'Crack', 'Structural Safety'],
    href: '/en/products/fbg-displacement-sensor',
    image: '/images/products/fbg-displacement-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Inclinometer & Tilt Sensor',
    desc: 'Tilt, settlement, and differential deformation monitoring for buildings, bridges, and large structures.',
    tags: ['Tilt', 'Settlement', 'Long-Term'],
    href: '/en/products/fbg-inclinometer',
    image: '/images/products/fbg-inclinometer-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Accelerometer',
    desc: 'Vibration response, modal analysis, and condition monitoring for bridges, turbines, rail, and industrial equipment.',
    tags: ['Vibration', 'Acceleration', 'Diagnostics'],
    href: '/en/products/fbg-accelerometer',
    image: '/images/products/fbg-accelerometer-thumbnail.png',
  },
  {
    category: 'FBG SENSOR',
    title: 'FBG Pressure & Load Sensor',
    desc: 'Pressure and load monitoring for vessels, tanks, foundations, and special engineering applications.',
    tags: ['Pressure', 'Load', 'Industrial'],
    href: '/en/products/fbg-pressure-sensor',
    image: '/images/products/fbg-pressure-thumbnail.png',
  },
];

const aiFeatures = [
  {
    title: 'Multi-Source Data Integration',
    desc: 'Aggregating data from fiber interrogators, distributed monitors, environmental sensors, video, and third-party systems.',
    icon: 'mdi:database-outline',
  },
  {
    title: 'Intelligent Anomaly Detection',
    desc: 'Combining thresholds, trends, correlation rules, and model analysis to identify abnormal conditions and potential risks.',
    icon: 'mdi:alert-decagram-outline',
  },
  {
    title: 'Trend Prediction & Risk Assessment',
    desc: 'Identifying change patterns, performing correlation analysis, and evaluating risk levels from long-term monitoring data.',
    icon: 'mdi:chart-timeline-variant',
  },
  {
    title: 'Smart Reports & O&M Support',
    desc: 'Automatically generating status reports, alarm records, and maintenance recommendations to improve project management efficiency.',
    icon: 'mdi:file-chart-outline',
  },
];
---
<Layout>
  <div slot="content" class="pt-16">

    <!-- ===== Hero ===== -->
    <section class="border-b border-dashed border-slate-200 bg-white px-6 py-16 text-slate-900 lg:px-8 lg:py-20">
      <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.05fr_.95fr] lg:gap-16">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
            <span class="h-px w-8 bg-cyan-600"></span>
            Products
          </div>
          <h1 class="mt-5 text-4xl font-semibold leading-[1.15] tracking-tight sm:text-5xl lg:text-6xl">
            Fiber Optic Sensing Products
            <span class="block text-cyan-600">& Intelligent Monitoring Systems</span>
          </h1>
          <p class="mt-6 text-base leading-8 text-slate-600 sm:text-lg">
            Covering FBG interrogators, DAS / DTS distributed monitoring instruments,
            FBG fiber optic sensors, and AI intelligent monitoring systems
            for structural safety, energy infrastructure, and industrial equipment.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#interrogators" class="btn btn-primary btn-lg">
              Browse Products
              <Icon name="mdi:arrow-down" width="18" height="18" />
            </a>
            <a href="/en/contact#contact" class="btn btn-outline btn-lg border-slate-300 text-slate-700 hover:border-cyan-600 hover:bg-cyan-600 hover:text-white">
              Get Selection Advice
            </a>
          </div>
          <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3 border-t border-slate-200 pt-6 text-sm text-slate-500">
            <span>Standard Products</span>
            <span>OEM / ODM Custom</span>
            <span>Project-Level Support</span>
          </div>
        </div>

        <!-- Right visual area -->
        <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 p-8 sm:p-10">
          <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-cyan-100 blur-3xl"></div>
          <div class="relative grid grid-cols-2 gap-4">
            <div class="rounded-2xl bg-slate-900 p-6 text-white">
              <div class="text-xs font-medium tracking-[0.14em] text-cyan-300">INTERROGATOR</div>
              <div class="mt-3 text-2xl font-semibold">Monitoring</div>
              <p class="mt-3 text-sm leading-6 text-slate-400">FBG, DAS, DTS fiber monitoring & data acquisition.</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-6">
              <div class="text-xs font-medium tracking-[0.14em] text-cyan-700">SENSOR</div>
              <div class="mt-3 text-2xl font-semibold text-slate-900">FBG Sensing</div>
              <p class="mt-3 text-sm leading-6 text-slate-500">Strain, temperature, displacement, pressure, tilt & vibration.</p>
            </div>
            <div class="col-span-2 rounded-2xl border border-cyan-100 bg-cyan-50 p-6">
              <div class="flex items-center justify-between gap-6">
                <div>
                  <div class="text-xs font-medium tracking-[0.14em] text-cyan-700">AI MONITORING SYSTEM</div>
                  <div class="mt-2 text-2xl font-semibold text-slate-900">AI Intelligent Monitoring System</div>
                </div>
                <Icon name="mdi:brain" width="46" height="46" class="shrink-0 text-cyan-600" />
              </div>
              <p class="mt-4 text-sm leading-6 text-slate-500">Multi-source data fusion, intelligent anomaly detection, trend prediction & O&M support.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Sticky Nav ===== -->
    <div class="sticky top-16 z-40 border-b border-slate-200 bg-white/90 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl gap-6 overflow-x-auto px-6 py-4 text-sm lg:px-8">
        <a href="#interrogators" class="whitespace-nowrap font-semibold text-cyan-700">Interrogators & Instruments</a>
        <a href="#sensors" class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700">FBG Sensors</a>
        <a href="#ai-monitoring" class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700">AI Monitoring System</a>
        <a href="#custom" class="whitespace-nowrap text-slate-600 transition hover:text-cyan-700">Custom Products</a>
      </div>
    </div>

    <!-- ===== Interrogators ===== -->
    <section id="interrogators" class="scroll-mt-28 border-b border-dashed border-slate-200 bg-slate-50 px-6 py-24 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col justify-between gap-8 lg:flex-row lg:items-end">
          <div class="max-w-2xl">
            <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
              <span class="h-px w-8 bg-cyan-600"></span>
              Interrogators & Monitoring Instruments
            </div>
            <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">Core Fiber Monitoring Equipment</h2>
            <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
              For FBG point sensing, DAS distributed acoustic sensing, and DTS distributed temperature
              monitoring — providing integrated devices for optical signal acquisition, data demodulation,
              online analysis, and alarm linkage.
            </p>
          </div>
          <a href="/en/contact#contact" class="group inline-flex w-fit items-center gap-3 border-b border-slate-300 pb-2 text-sm font-medium text-slate-700 transition hover:border-cyan-600 hover:text-cyan-700">
            Get Equipment Selection Advice
            <span class="text-lg transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>

        <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {interrogatorProducts.map((item) => (
            <a href={item.href} class="group flex min-h-[360px] flex-col rounded-2xl border border-slate-200 bg-white p-7 transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5">
              <div class="flex items-start justify-between">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-50 text-cyan-700">
                  <Icon name={item.icon} width="26" height="26" />
                </div>
                <span class="text-sm font-medium text-slate-400">{item.no}</span>
              </div>
              <div class="mt-8 text-xs font-medium tracking-[0.12em] text-cyan-700">{item.category}</div>
              <h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">{item.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">{item.desc}</p>
              <div class="mt-6 flex flex-wrap gap-2">
                {item.tags.map((tag) => (<span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-500">{tag}</span>))}
              </div>
              <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-5">
                <span class="text-sm font-medium text-slate-500">View Details</span>
                <span class="text-lg text-cyan-700 transition-transform group-hover:translate-x-1">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FBG Sensors ===== -->
    <section id="sensors" class="scroll-mt-28 border-b border-dashed border-slate-200 bg-white px-6 py-24 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col justify-between gap-8 lg:flex-row lg:items-end">
          <div class="max-w-2xl">
            <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
              <span class="h-px w-8 bg-cyan-600"></span>
              FBG Fiber Optic Sensors
            </div>
            <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">High-Precision Point Sensing</h2>
            <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
              Offering a wide range of FBG fiber optic sensors — strain, temperature, displacement,
              crack, tilt, leveling, acceleration, pressure, and load — for structural safety,
              energy facilities, industrial equipment, and research applications.
            </p>
          </div>
          <a href="/en/contact#contact" class="group inline-flex w-fit items-center gap-3 border-b border-slate-300 pb-2 text-sm font-medium text-slate-700 transition hover:border-cyan-600 hover:text-cyan-700">
            Get Sensor Selection Advice
            <span class="text-lg transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>

        <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {fbgProducts.map((item) => (
            <a href={item.href} class="group flex min-h-[390px] flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5">
              <div class="aspect-[3/2] overflow-hidden bg-slate-50 p-6">
                <img src={item.image} alt={item.title} class="h-full w-full object-contain transition duration-300 group-hover:scale-105" />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="text-xs font-medium tracking-[0.12em] text-cyan-700">{item.category}</div>
                <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{item.desc}</p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {item.tags.map((tag) => (<span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-500">{tag}</span>))}
                </div>
                <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-5">
                  <span class="text-sm font-medium text-slate-500">View Details</span>
                  <span class="text-lg text-cyan-700 transition-transform group-hover:translate-x-1">→</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== AI Monitoring System ===== -->
    <section id="ai-monitoring" class="scroll-mt-28 border-b border-dashed border-slate-800 bg-slate-950 px-6 py-24 text-white lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1fr_.9fr] lg:items-center">
        <div>
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-300">
            <span class="h-px w-8 bg-cyan-300"></span>
            AI MONITORING SYSTEM
          </div>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">AI Intelligent Monitoring System</h2>
          <p class="mt-6 max-w-2xl text-base leading-8 text-slate-300 sm:text-lg">
            Unifying data from fiber interrogators, distributed monitors, FBG sensors, and
            third-party devices — enabling data governance, anomaly detection, trend prediction,
            intelligent alerts, and O&M support to improve analytical efficiency and decision value.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <span class="rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-2 text-sm text-cyan-200">Multi-Source Data Integration</span>
            <span class="rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-2 text-sm text-cyan-200">Intelligent Anomaly Detection</span>
            <span class="rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-2 text-sm text-cyan-200">Trend Prediction</span>
            <span class="rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-2 text-sm text-cyan-200">Alert Lifecycle Management</span>
          </div>
          <a href="/en/products/ai-monitoring-system" class="mt-10 inline-flex items-center gap-3 rounded-xl bg-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300">
            View AI Monitoring System
            <Icon name="mdi:arrow-up-right" width="18" height="18" />
          </a>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur sm:p-8">
          <div class="grid gap-4 sm:grid-cols-2">
            {aiFeatures.map((item) => (
              <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-5">
                <Icon name={item.icon} width="28" height="28" class="text-cyan-300" />
                <h3 class="mt-5 text-lg font-semibold">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-400">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Custom ===== -->
    <section id="custom" class="scroll-mt-28 border-t border-dashed border-slate-200 bg-gradient-to-br from-cyan-50 via-white to-slate-50 px-6 py-20 text-slate-900 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="overflow-hidden rounded-3xl border border-cyan-100 bg-white shadow-[0_20px_60px_rgba(8,145,178,0.08)]">
          <div class="grid gap-10 p-7 sm:p-10 lg:grid-cols-[1.1fr_.9fr] lg:items-center lg:p-14">
            <div>
              <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
                <span class="h-px w-8 bg-cyan-600"></span>
                OEM / ODM & Custom Products
              </div>
              <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
                Can't Find the Right
                <span class="block text-cyan-600">Standard Product? We Customize.</span>
              </h2>
              <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">
                Custom sensor ranges, dimensions, packaging, fiber length, connectors,
                temperature rating, protection class, and communication protocols
                based on site conditions and system requirements.
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">Fast Delivery</span>
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">Project Adaptation</span>
                <span class="rounded-full border border-cyan-100 bg-cyan-50 px-4 py-2 text-sm text-cyan-800">OEM / ODM</span>
              </div>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-7">
              <div class="text-sm font-medium text-slate-900">Customization Scope</div>
              <div class="mt-5 grid gap-3 text-sm sm:grid-cols-2">
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">Size & Packaging</div>
                  <div class="mt-1 text-xs leading-5 text-slate-500">Form factor, mounting, materials & protection</div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">Range & Accuracy</div>
                  <div class="mt-1 text-xs leading-5 text-slate-500">Optimized parameters for different applications</div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">Special Environments</div>
                  <div class="mt-1 text-xs leading-5 text-slate-500">High temp, humidity, corrosion, outdoor & tight spaces</div>
                </div>
                <div class="rounded-xl border border-slate-200 bg-white p-4 text-slate-600">
                  <div class="font-medium text-slate-900">System Integration</div>
                  <div class="mt-1 text-xs leading-5 text-slate-500">Data acquisition, protocol & platform coordination</div>
                </div>
              </div>
              <a href="/en/contact#contact" class="mt-7 inline-flex items-center gap-3 rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-cyan-700">
                Contact Technical Team
                <Icon name="mdi:arrow-up-right" width="17" height="17" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>
</Layout>
