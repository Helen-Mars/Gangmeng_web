---
import { Icon } from "astro-icon/components";
// import SolutionApp1 from "../../assets/application/solution1.jpg";

const applications = [
  {
    no: "01",
    title: "Bridges & Building Structures",
    desc: "Long-term structural health monitoring for bridges, buildings, long-span structures, foundations, and critical load-bearing components.",
    tags: ["Strain", "Displacement", "Tilt", "Vibration"],
    href: "/en/applications/structure-monitoring",
  },
  {
    no: "02",
    title: "Tunnels & Rail Transit",
    desc: "Continuous sensing for tunnel surrounding rock, linings, settlement, rail vibration, and structural conditions along transit routes.",
    tags: ["Settlement", "Cracks", "Vibration", "Intrusion"],
    href: "/en/applications/tunnel-rail",
  },
  {
    no: "03",
    title: "Power Cables & Energy Pipelines",
    desc: "Real-time warning for cable temperature rise, joint overheating, pipeline leakage, and third-party construction intrusion.",
    tags: ["DTS", "DAS", "Temperature", "Leak Detection"],
    href: "/en/applications/energy-pipeline",
  },
  {
    no: "04",
    title: "Wind Power & Renewable Energy",
    desc: "Condition monitoring for wind turbine towers, blades, foundations, and equipment across renewable energy facilities.",
    tags: ["Load", "Vibration", "Temperature", "Fatigue"],
    href: "/en/applications/wind-power",
  },
  {
    no: "05",
    title: "Industrial Equipment & Smart Manufacturing",
    desc: "Condition diagnostics for critical machinery, storage tanks, pressure vessels, production lines, and large industrial equipment.",
    tags: ["Vibration", "Temperature", "Pressure", "Diagnostics"],
    href: "/en/applications/industrial",
  },
  {
    no: "06",
    title: "Agricultural Facilities & Cold Chain",
    desc: "Precision temperature monitoring for cold storage, plant factories, seed banks, cultivation chambers, and agricultural environments.",
    tags: ["Cold Chain", "Temperature", "Environment", "Alerts"],
    href: "/en/applications/agriculture",
  },
];

const advantages = [
  {
    no: "01",
    title: "In-House R&D & Manufacturing",
    desc: "Covering sensors, interrogators, distributed monitoring equipment, and software platforms to support stable supply and continuous product development.",
  },
  {
    no: "02",
    title: "Custom Engineering",
    desc: "Sensor and system-level solutions can be tailored to the monitored object, installation environment, measurement range, accuracy, and communication requirements.",
  },
  {
    no: "03",
    title: "Project-Level Technical Support",
    desc: "Technical support throughout product selection, monitoring-point planning, installation guidance, system commissioning, and long-term maintenance.",
  },
  {
    no: "04",
    title: "Competitive Cost & Delivery",
    desc: "Our in-house R&D and manufacturing capabilities support competitive solutions for volume procurement, OEM/ODM projects, and engineering delivery.",
  },
];

const solutions = [
  {
    no: "01",
    category: "STRUCTURAL SAFETY",
    title: "Bridge & Building Structural Health Monitoring",
    desc: "Using FBG strain, temperature, displacement, tilt, and acceleration sensors to monitor critical members, mid-span areas, supports, and overall structural conditions.",
    image: "/images/solution-bridge.jpg",
    tags: ["FBG Strain", "Displacement", "Vibration"],
    href: "/en/solutions/bridge-structure",
  },
  {
    no: "02",
    category: "ENERGY SECURITY",
    title: "Power Cable & Pipeline Monitoring",
    desc: "Combining DTS distributed temperature sensing and DAS distributed acoustic sensing for continuous monitoring and early warning of overheating, hot spots, leakage, and intrusion.",
    image: "/images/solution-energy.jpg",
    tags: ["DTS Temperature", "DAS Acoustic", "Leak Detection"],
    href: "/en/solutions/energy-pipeline",
  },
  {
    no: "03",
    category: "AGRICULTURAL ENVIRONMENT",
    title: "Agricultural & Cold-Chain Environmental Monitoring",
    desc: "Designed for cold storage, plant factories, seed banks, cultivation chambers, and equipment rooms, with multi-zone, high-density, traceable temperature monitoring.",
    image: "/images/solution-agriculture.jpg",
    tags: ["Temperature", "Cold Chain", "Alarm System"],
    href: "/en/solutions/agriculture-coldchain",
  },
];
---

<!-- ===== Hero ===== -->
<section class="relative overflow-hidden border-b border-dashed border-slate-300/70 bg-white text-slate-900">
  <div class="relative mx-auto flex max-w-[1360px] items-center px-6 py-16 lg:min-h-[760px] lg:px-8 lg:py-16">
    <div class="grid w-full items-center gap-10 lg:grid-cols-2 lg:gap-12">

      <div class="max-w-2xl">
        <div class="mb-5 flex items-center gap-3 text-sm font-medium text-cyan-700">
          <span class="h-px w-8 bg-cyan-600"></span>
          Fiber Sensor & Intelligent Monitoring System Manufacturer
        </div>

        <h1 class="text-4xl font-semibold leading-[1.15] tracking-tight sm:text-5xl lg:text-6xl">
          Every Fiber Senses
          <span class="block text-cyan-600">Every Critical Change</span>
        </h1>

        <p class="mt-6 text-base leading-8 text-slate-600 sm:text-lg">
          We provide FBG fiber optic sensors, DTS distributed temperature sensing
          systems, DAS distributed acoustic sensing systems, and integrated data
          acquisition platforms for structural safety, energy assets, and industrial equipment.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/en/products" class="btn btn-primary btn-lg">
            Explore Products
            <Icon name="mdi:arrow-right" width="18" height="18" />
          </a>

          <a
            href="/en/contact#contact"
            class="btn btn-outline btn-lg border-slate-300 text-slate-700 hover:border-cyan-600 hover:bg-cyan-600 hover:text-white"
          >
            Request a Technical Solution
          </a>
        </div>

        <div class="mt-10 flex flex-wrap gap-x-8 gap-y-4 border-t border-slate-200 pt-6">
          <div>
            <div class="text-lg font-semibold text-slate-900">FBG</div>
            <div class="mt-1 text-sm text-slate-500">Fiber Bragg Grating Sensors</div>
          </div>

          <div>
            <div class="text-lg font-semibold text-slate-900">DTS</div>
            <div class="mt-1 text-sm text-slate-500">Distributed Temperature Sensing</div>
          </div>

          <div>
            <div class="text-lg font-semibold text-slate-900">DAS</div>
            <div class="mt-1 text-sm text-slate-500">Distributed Acoustic Sensing</div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="relative overflow-hidden rounded-2xl bg-slate-100">
          <img
            src="/images/solution1.jpg"
            alt="Gangmeng Sensor fiber optic monitoring system"
            class="h-[320px] w-full object-cover sm:h-[400px] lg:h-[470px]"
          />

          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-950/75 to-transparent px-6 pb-6 pt-20 text-white">
            <div class="text-sm text-slate-300">Fiber Sensing System</div>
            <div class="mt-1 text-xl font-semibold">
              Fiber Monitoring & Data Analytics Platform
            </div>
          </div>
        </div>

        <div class="absolute -bottom-4 -left-4 hidden rounded-xl border border-slate-200 bg-white px-5 py-4 shadow-lg lg:block">
          <div class="text-xs text-slate-500">Application Areas</div>
          <div class="mt-1 text-sm font-semibold text-slate-800">
            Infrastructure · Energy · Industry · Agriculture
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ===== Core Product Portfolio ===== -->
<section
  id="products"
  class="border-b border-dashed border-slate-200 bg-slate-50 px-6 py-24 text-slate-900 lg:px-8"
>
  <div class="mx-auto max-w-7xl">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
        <span class="h-px w-8 bg-cyan-600"></span>
        Core Product Portfolio
      </div>

      <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
        From Point Sensing to Distributed Monitoring
      </h2>

      <p class="mt-5 text-base leading-8 text-slate-600 sm:text-lg">
        Covering key monitoring parameters including strain, temperature,
        vibration, and acoustic signals for structural safety, energy assets,
        and industrial equipment.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-3">
      <a
        href="/en/products/fbg"
        class="group relative flex min-h-[330px] flex-col justify-between overflow-hidden rounded-2xl border border-slate-200 bg-white p-7 transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5"
      >
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-50 text-cyan-700">
            <Icon name="mdi:chart-timeline-variant" width="25" height="25" />
          </div>

          <div class="mt-8 text-sm font-medium text-cyan-700">01 / FBG</div>

          <h3 class="mt-3 text-2xl font-semibold tracking-tight">
            Fiber Bragg Grating Sensors
          </h3>

          <p class="mt-4 leading-7 text-slate-600">
            Multi-parameter fiber optic sensing products for strain, temperature,
            displacement, pressure, tilt, crack monitoring, and acceleration.
          </p>
        </div>

        <div class="mt-10 flex items-center justify-between border-t border-slate-100 pt-5">
          <span class="text-sm font-medium text-slate-500">
            High-Precision Point Monitoring
          </span>
          <span class="text-lg text-cyan-700 transition-transform duration-300 group-hover:translate-x-1">→</span>
        </div>
      </a>

      <a
        href="/en/products/dts"
        class="group relative flex min-h-[330px] flex-col justify-between overflow-hidden rounded-2xl border border-slate-200 bg-white p-7 transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5"
      >
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-50 text-cyan-700">
            <Icon name="mdi:thermometer-lines" width="25" height="25" />
          </div>

          <div class="mt-8 text-sm font-medium text-cyan-700">02 / DTS</div>

          <h3 class="mt-3 text-2xl font-semibold tracking-tight">
            Distributed Temperature Sensing
          </h3>

          <p class="mt-4 leading-7 text-slate-600">
            Continuous fiber optic temperature sensing for long-distance,
            multi-zone, high-density temperature monitoring and early warning.
          </p>
        </div>

        <div class="mt-10 flex items-center justify-between border-t border-slate-100 pt-5">
          <span class="text-sm font-medium text-slate-500">
            Continuous Temperature Monitoring
          </span>
          <span class="text-lg text-cyan-700 transition-transform duration-300 group-hover:translate-x-1">→</span>
        </div>
      </a>

      <a
        href="/en/products/das"
        class="group relative flex min-h-[330px] flex-col justify-between overflow-hidden rounded-2xl border border-slate-200 bg-white p-7 transition duration-300 hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-900/5"
      >
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-50 text-cyan-700">
            <Icon name="mdi:waveform" width="25" height="25" />
          </div>

          <div class="mt-8 text-sm font-medium text-cyan-700">03 / DAS</div>

          <h3 class="mt-3 text-2xl font-semibold tracking-tight">
            Distributed Acoustic Sensing
          </h3>

          <p class="mt-4 leading-7 text-slate-600">
            Real-time sensing of vibration, intrusion, leakage, and equipment
            operating conditions for long-distance distributed monitoring.
          </p>
        </div>

        <div class="mt-10 flex items-center justify-between border-t border-slate-100 pt-5">
          <span class="text-sm font-medium text-slate-500">
            Vibration & Acoustic Monitoring
          </span>
