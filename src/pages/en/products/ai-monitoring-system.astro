---
import Layout from "@/layouts/en/Layout.astro";
import { Icon } from "astro-icon/components";

const specifications = [
  ["Product Name", "AI Intelligent Monitoring System"],
  ["System Positioning", "Unified monitoring and analysis platform for fiber optic sensing, distributed monitoring, and multi-source equipment data"],
  ["Data Access", "FBG interrogators, DAS, DTS, environmental devices, video, and third-party systems"],
  ["Platform Architecture", "B/S architecture, supporting local deployment, private deployment, or cloud deployment"],
  ["Data Protocol", "Modbus TCP, MQTT, HTTP API, database interface, or project-customized interface"],
  ["Monitoring Methods", "Real-time data display, historical data query, trend analysis, event playback, and alert management"],
  ["Anomaly Detection", "Threshold alerts, trend identification, correlation rules, model analysis, and project-specific algorithm configuration"],
  ["Risk Assessment", "Risk level evaluation, change trend identification, and multi-dimensional correlation analysis"],
  ["Visualization", "Monitoring overview, device status, data curves, alert center, reports, and project map"],
  ["Reporting", "Daily, weekly, monthly reports, alert records, and project-customized report export"],
  ["User Permissions", "Multi-role, multi-project, multi-level permission management"],
  ["Data Storage", "Local database, server storage, private cloud, or project-designated storage method"],
  ["System Integration", "Integration with existing monitoring platforms, O&M systems, video platforms, and third-party business systems"],
];

const features = [
  {
    title: "Multi-Source Data Integration",
    desc: "Aggregating data from fiber interrogators, distributed monitors, environmental sensors, video, and third-party systems.",
    icon: "mdi:database-outline",
  },
  {
    title: "Intelligent Anomaly Detection",
    desc: "Combining thresholds, trends, correlation rules, and model analysis to identify abnormal conditions and potential risks.",
    icon: "mdi:alert-decagram-outline",
  },
  {
    title: "Trend Prediction & Risk Assessment",
    desc: "Identifying change patterns, performing correlation analysis, and evaluating risk levels from long-term monitoring data.",
    icon: "mdi:chart-timeline-variant",
  },
  {
    title: "Smart Reports & O&M Support",
    desc: "Automatically generating status reports, alarm records, and maintenance recommendations to improve project management efficiency.",
    icon: "mdi:file-chart-outline",
  },
];
---

<Layout>
  <div slot="content" class="pt-16">
        <!-- 顶部产品展示：左侧系统视觉，右侧参数 -->
    <section class="border-b border-slate-200 bg-slate-50 px-6 py-12 text-slate-900 lg:px-8 lg:py-16">
      <div class="mx-auto max-w-7xl">
        <!-- 面包屑 -->
        <div class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
          <a href="/en/products#ai-monitoring" class="transition hover:text-cyan-700">Products</a>
          <span>/</span>
          <a href="/en/products#ai-monitoring" class="transition hover:text-cyan-700">AI Monitoring System</a>
          <span>/</span>
          <span class="text-slate-700">AI Intelligent Monitoring System</span>
        </div>

        <!-- 统一产品卡片 -->
        <div class="mt-8 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-[0_18px_55px_rgba(15,23,42,0.06)]">
          <div class="grid lg:grid-cols-[.9fr_1.1fr]">
            <!-- 左侧系统展示 -->
            <div class="relative overflow-hidden border-b border-slate-200 bg-gradient-to-br from-slate-950 via-slate-900 to-cyan-950 p-6 sm:p-10 lg:border-b-0 lg:border-r">
              <div class="absolute -left-20 -top-24 h-72 w-72 rounded-full bg-cyan-400/15 blur-3xl"></div>
              <div class="absolute -bottom-24 -right-20 h-72 w-72 rounded-full bg-blue-500/15 blur-3xl"></div>

              <div class="relative flex aspect-[4/3] flex-col overflow-hidden rounded-2xl border border-white/10 bg-slate-950/70 p-5 shadow-2xl">
                <!-- 顶部状态栏 -->
                <div class="flex items-center justify-between border-b border-white/10 pb-4">
                  <div class="flex items-center gap-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-300">
                      <Icon name="mdi:brain" width="20" height="20" />
                    </div>

                    <div>
                      <div class="text-sm font-semibold text-white">AI Monitoring Center</div>
                      <div class="mt-0.5 text-xs text-slate-400">Real-time data analysis</div>
                    </div>
                  </div>

                  <div class="flex items-center gap-2 rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs text-emerald-300">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-300"></span>
                    Online
                  </div>
                </div>

                <!-- 数据指标 -->
                <div class="mt-5 grid grid-cols-3 gap-3">
                  <div class="rounded-xl border border-white/10 bg-white/[0.04] p-3">
                    <div class="text-xs text-slate-400">Devices Connected</div>
                    <div class="mt-2 text-xl font-semibold text-white">128</div>
                  </div>

                  <div class="rounded-xl border border-white/10 bg-white/[0.04] p-3">
                    <div class="text-xs text-slate-400">Online Rate</div>
                    <div class="mt-2 text-xl font-semibold text-cyan-300">99.8%</div>
                  </div>

                  <div class="rounded-xl border border-white/10 bg-white/[0.04] p-3">
                    <div class="text-xs text-slate-400">Active Alerts</div>
                    <div class="mt-2 text-xl font-semibold text-amber-300">03</div>
                  </div>
                </div>

                <!-- 趋势图区域 -->
                <div class="mt-4 flex-1 rounded-xl border border-white/10 bg-white/[0.035] p-4">
                  <div class="flex items-center justify-between">
                    <div class="text-xs font-medium text-slate-300">Monitoring Trend</div>
                    <div class="text-xs text-cyan-300">Last 24 Hours</div>
                  </div>

                  <div class="relative mt-5 h-24 overflow-hidden">
                    <div class="absolute inset-x-0 top-1/4 border-t border-dashed border-white/10"></div>
                    <div class="absolute inset-x-0 top-2/4 border-t border-dashed border-white/10"></div>
                    <div class="absolute inset-x-0 top-3/4 border-t border-dashed border-white/10"></div>

                    <svg viewBox="0 0 400 100" class="absolute inset-0 h-full w-full" preserveAspectRatio="none" aria-hidden="true">
                      <path d="M0,72 C25,68 30,52 55,58 C80,64 88,35 115,43 C140,50 153,69 178,60 C205,50 220,25 248,40 C272,53 285,44 308,35 C332,25 350,50 375,38 C385,34 392,30 400,25" fill="none" stroke="rgb(34 211 238)" stroke-width="3" />
                    </svg>
                  </div>

                  <div class="mt-3 flex justify-between text-[10px] text-slate-500">
                    <span>00:00</span>
                    <span>06:00</span>
                    <span>12:00</span>
                    <span>18:00</span>
                    <span>Now</span>
                  </div>
                </div>

                <!-- 系统节点 -->
                <div class="mt-4 grid grid-cols-2 gap-3">
                  <div class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/[0.04] p-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-300">
                      <Icon name="mdi:access-point-network" width="18" height="18" />
                    </div>
                    <div>
                      <div class="text-xs font-medium text-white">Data Access</div>
                      <div class="mt-1 text-[11px] text-slate-400">FBG / DAS / DTS</div>
                    </div>
                  </div>

                  <div class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/[0.04] p-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-violet-400/10 text-violet-300">
                      <Icon name="mdi:robot-outline" width="18" height="18" />
                    </div>
                    <div>
                      <div class="text-xs font-medium text-white">AI Analysis</div>
                      <div class="mt-1 text-[11px] text-slate-400">Alert & Risk Review</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- 右侧产品型号与技术参数 -->
            <div class="p-6 sm:p-8 lg:p-10">
              <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
                <span class="h-px w-8 bg-cyan-600"></span>
                AI MONITORING SYSTEM
              </div>

              <h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">AI Intelligent Monitoring System</h1>

              <p class="mt-4 max-w-2xl leading-7 text-slate-600">
                Designed for comprehensive online monitoring of engineering structures, energy facilities, industrial equipment, and complex scenarios — unifying FBG, DAS, DTS, environmental devices, video, and third-party system data for intelligent analysis, risk assessment, and alert management, enhancing digital O&M capabilities.
              </p>

              <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
                <table class="w-full border-collapse text-sm">
                  <tbody>
                    {
                      specifications.map(([label, value]) => (
                        <tr class="border-b border-slate-200 last:border-b-0">
                          <th class="w-[34%] bg-slate-50 px-4 py-3 text-left font-semibold text-slate-700 sm:px-5">{label}</th>
                          <td class="px-4 py-3 leading-6 text-slate-600 sm:px-5">{value}</td>
                        </tr>
                      ))
                    }
                  </tbody>
                </table>
              </div>

              <div class="mt-6 flex flex-wrap gap-3">
                <a href="/en/contact#contact" class="inline-flex items-center gap-3 rounded-xl bg-cyan-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-cyan-700">
                  Get System Solution
                  <Icon name="mdi:arrow-up-right" width="17" height="17" />
                </a>

                <a href="/en/products#ai-monitoring" class="inline-flex items-center gap-3 rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-cyan-600 hover:text-cyan-700">
                  Back to Products
                  <Icon name="mdi:arrow-left" width="17" height="17" />
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 产品优势 -->
    <section class="bg-slate-50 px-6 py-16 text-slate-900 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-7xl">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 text-sm font-medium text-cyan-700">
            <span class="h-px w-8 bg-cyan-600"></span>
            PRODUCT ADVANTAGES
          </div>

          <h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">Product Advantages</h2>

          <p class="mt-4 leading-8 text-slate-600">
            A unified data hub connecting field monitoring devices and business systems, forming a closed-loop monitoring capability from data acquisition, intelligent analysis, anomaly alerting, to O&M management.
          </p>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
          {
            features.map((item) => (
              <div class="rounded-2xl border border-slate-200 bg-white p-6">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-50 text-cyan-700">
                  <Icon name={item.icon} width="25" height="25" />
                </div>

                <h3 class="mt-5 text-lg font-semibold text-slate-900">
                  {item.title}
                </h3>

                <p class="mt-3 text-sm leading-7 text-slate-600">
                  {item.desc}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</Layout>

