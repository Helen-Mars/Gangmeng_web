---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div slot="content" class="pt-16">

    <section
      id="contact"
      class="border-b border-dashed border-slate-200 bg-gradient-to-br from-cyan-50 via-white to-slate-50 px-6 py-20 text-slate-900 lg:px-8"
    >
      <div class="mx-auto max-w-7xl">
        <div class="overflow-hidden rounded-3xl border border-cyan-100 bg-white shadow-[0_20px_60px_rgba(8,145,178,0.08)]">
          <div class="grid lg:grid-cols-[1fr_1.05fr]">

            <!-- 左侧文案 -->
            <div class="relative overflow-hidden bg-slate-950 px-7 py-12 text-white sm:px-10 lg:px-12 lg:py-14">
              <div class="pointer-events-none absolute -left-20 -top-20 h-72 w-72 rounded-full bg-cyan-400/20 blur-3xl"></div>
              <div class="pointer-events-none absolute -bottom-24 right-0 h-72 w-72 rounded-full bg-blue-500/20 blur-3xl"></div>

              <div class="relative">
                <div class="flex items-center gap-3 text-sm font-medium text-cyan-300">
                  <span class="h-px w-8 bg-cyan-300"></span>
                  联系港盟传感
                </div>

                <h1 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">
                  告诉我们您的需求
                  <span class="block text-cyan-300">获取专业技术支持</span>
                </h1>

                <p class="mt-6 max-w-lg text-base leading-8 text-slate-300">
                  无论您需要单个光纤传感器、分布式监测设备，
                  还是完整的工程监测系统，我们将根据应用场景提供产品选型与部署建议。
                </p>

                <div class="mt-10 grid gap-4 border-t border-white/10 pt-8">
                  <div>
                    <div class="text-xs tracking-[0.14em] text-slate-400">
                      SERVICE SCOPE
                    </div>
                    <p class="mt-3 text-sm leading-7 text-slate-300">
                      产品选型 · OEM / ODM · 项目方案 · 安装部署 · 系统调试 · 海外交付
                    </p>
                  </div>

                  <div>
                    <div class="text-xs tracking-[0.14em] text-slate-400">
                      RESPONSE
                    </div>
                    <p class="mt-3 text-sm leading-7 text-slate-300">
                      请通过电话、邮箱、WhatsApp 或微信直接联系技术团队。
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- 右侧联系入口 -->
            <div class="flex bg-slate-50 p-7 sm:p-10 lg:p-12">
              <div class="mx-auto w-full max-w-xl">

                <div class="text-center">
                  <div class="text-sm font-medium text-cyan-700">快速咨询</div>

                  <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
                    与技术团队直接沟通
                  </h2>

                  <p class="mx-auto mt-3 max-w-md text-sm leading-7 text-slate-500">
                    可咨询产品参数、项目部署、系统配置、定制开发及海外交付。
                  </p>
                </div>

                <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2">

                  <a
                    href="tel:+8613800000000"
                    class="group rounded-2xl border border-slate-200 bg-white p-5 transition hover:-translate-y-0.5 hover:border-cyan-500 hover:shadow-lg"
                  >
                    <div class="flex items-center justify-between">
                      <span class="text-xs tracking-[0.12em] text-slate-400 uppercase">
                        Phone
                      </span>
                      <Icon
                        name="mdi:arrow-right"
                        width="18"
                        height="18"
                        class="text-cyan-700 transition-transform group-hover:translate-x-1"
                      />
                    </div>

                    <div class="mt-4 text-base font-semibold text-slate-900">
                      +86 138 0000 0000
                    </div>

                    <div class="mt-1 text-sm text-slate-500">
                      电话咨询
                    </div>
                  </a>

                  <a
                    href="mailto:sales@example.com"
                    class="group rounded-2xl border border-slate-200 bg-white p-5 transition hover:-translate-y-0.5 hover:border-cyan-500 hover:shadow-lg"
                  >
                    <div class="flex items-center justify-between">
                      <span class="text-xs tracking-[0.12em] text-slate-400 uppercase">
                        Email
                      </span>
                      <Icon
                        name="mdi:arrow-right"
                        width="18"
                        height="18"
                        class="text-cyan-700 transition-transform group-hover:translate-x-1"
                      />
                    </div>

                    <div class="mt-4 break-all text-base font-semibold text-slate-900">
                      sales@example.com
                    </div>

                    <div class="mt-1 text-sm text-slate-500">
                      邮件咨询
                    </div>
                  </a>

                  <a
                    href="https://wa.me/8613800000000"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group rounded-2xl bg-slate-900 p-5 text-white transition hover:-translate-y-0.5 hover:bg-cyan-700 hover:shadow-lg"
                  >
                    <div class="flex items-center justify-between">
                      <span class="text-xs tracking-[0.12em] text-slate-400 uppercase group-hover:text-cyan-100">
                        WhatsApp
                      </span>
                      <Icon
                        name="mdi:arrow-right"
                        width="18"
                        height="18"
                        class="text-cyan-300 transition-transform group-hover:translate-x-1 group-hover:text-white"
                      />
                    </div>

                    <div class="mt-4 text-base font-semibold">
                      在线咨询产品与方案
                    </div>

                    <div class="mt-1 text-sm text-slate-400 group-hover:text-cyan-100">
                      海外客户快速沟通
                    </div>
                  </a>

                  <div class="rounded-2xl border border-slate-200 bg-white p-5">
                    <div class="text-xs tracking-[0.12em] text-slate-400 uppercase">
                      Technical Support
                    </div>

                    <div class="mt-4 text-base font-semibold text-slate-900">
                      项目级技术支持
                    </div>

                    <div class="mt-1 text-sm leading-6 text-slate-500">
                      选型 · 部署 · 调试 · 系统集成
                    </div>
                  </div>
                </div>

                <div class="mt-4 flex items-center gap-5 rounded-2xl border border-dashed border-slate-300 bg-white p-5">
                  <img
                    src="/images/wechat-qr.png"
                    alt="港盟传感微信咨询二维码"
                    class="h-20 w-20 shrink-0 rounded-xl object-cover"
                  />

                  <div>
                    <div class="font-semibold text-slate-900">微信扫码咨询</div>
                    <p class="mt-2 text-sm leading-6 text-slate-500">
                      添加技术顾问，获取产品目录、参数资料与项目建议。
                    </p>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>
</Layout>